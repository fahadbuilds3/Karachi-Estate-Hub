@{
    ViewBag.Title = "About";
}

<section class="section section-gray">
    <div style="max-width:900px;margin:0 auto">
        <p class="section-eyebrow">About Us</p>
        <h1 class="section-title" style="margin-bottom:16px">Karachi Estate Hub</h1>
        <div class="card-base" style="padding:28px">
            <p class="detail-desc">
                Karachi Estate Hub is a Karachi-focused property portal for buying, renting, and selling residential and commercial properties.
                Listings are managed by agents and reviewed through an admin workflow so users can browse active, verified opportunities with confidence.
            </p>
            <div class="why-grid" style="margin-top:22px">
                <div class="why-card"><div class="why-icon"><i class="ti ti-home-search"></i></div><div class="why-title">Buy & Rent</div><div class="why-desc">Search active listings across Karachi areas.</div></div>
                <div class="why-card"><div class="why-icon"><i class="ti ti-building-store"></i></div><div class="why-title">Agent Listings</div><div class="why-desc">Agents can submit and manage property listings.</div></div>
                <div class="why-card"><div class="why-icon"><i class="ti ti-shield-check"></i></div><div class="why-title">Admin Review</div><div class="why-desc">Admins approve, feature, and verify properties.</div></div>
            </div>
        </div>
    </div>
</section>
