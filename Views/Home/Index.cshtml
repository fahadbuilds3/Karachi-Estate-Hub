@model IEnumerable<KarachiEstateHub.Models.Property>

@{
    ViewBag.Title = "Find Your Perfect Property in Karachi";
    var listingsUrl = Url.RouteUrl("Listings");
    var createUrl = Url.RouteUrl("CreateListing");
    var userRole = Session["UserRole"] as string;
    var canAddProperty = userRole == "Admin" || userRole == "Agent";
    var addPropertyUrl = canAddProperty
        ? createUrl
        : Url.Action("Login", "Account", new { returnUrl = createUrl, message = "addProperty" });
    var activeListingsCount = ViewBag.ActiveListingsCount ?? 0;
    var majorAreasCount = ViewBag.MajorAreasCount ?? 0;
    var verifiedAgentsCount = ViewBag.VerifiedAgentsCount ?? 0;
    var locationCounts = ViewBag.LocationCounts as System.Collections.Generic.IDictionary<string, int>
        ?? new System.Collections.Generic.Dictionary<string, int>();
    System.Func<string, int> getLocationCount = name => locationCounts.ContainsKey(name) ? locationCounts[name] : 0;
}

<!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-badge">
        Karachi's #1 Property Portal
      </div>
      <h1 class="hero-title">Find Your Perfect Property<br>in Karachi</h1>
      <p class="hero-sub">Search houses, flats, portions, shops, and plots across all major areas of Karachi.</p>

      <!-- Hero Stats -->
      <div class="hero-stats">
        <div>
          <div class="hero-stat-val">@activeListingsCount</div>
          <div class="hero-stat-label">Active Listings</div>
        </div>
        <div>
          <div class="hero-stat-val">@majorAreasCount</div>
          <div class="hero-stat-label">Major Areas</div>
        </div>
        <div>
          <div class="hero-stat-val">@verifiedAgentsCount</div>
          <div class="hero-stat-label">Verified Agents</div>
        </div>
      </div>

      <!-- Search Card -->
      <div class="search-card">
        <div class="search-tabs">
          <button class="search-tab active" onclick="switchTab(this)">Buy</button>
          <button class="search-tab" onclick="switchTab(this)">Rent</button>
          <button class="search-tab" onclick="switchTab(this)">Commercial</button>
        </div>
        <div class="search-filters">
          <div class="filter-group">
            <label>Location</label>
            <select>
              <option value="">Any Area</option>
              <option>DHA Defence</option>
              <option>Clifton</option>
              <option>Gulshan-e-Iqbal</option>
              <option>Gulistan-e-Jauhar</option>
              <option>Bahria Town Karachi</option>
              <option>Scheme 33</option>
              <option>Malir</option>
              <option>North Nazimabad</option>
              <option>PECHS</option>
              <option>Nazimabad</option>
            </select>
          </div>
          <div class="filter-group">
            <label>Property Type</label>
            <select>
              <option value="">All Types</option>
              <option>House</option>
              <option>Flat / Apartment</option>
              <option>Portion</option>
              <option>Shop</option>
              <option>Plot / Land</option>
              <option>Office</option>
            </select>
          </div>
          <div class="filter-group">
            <label>Price Range</label>
            <select>
              <option value="">Any Price</option>
              <option>Under PKR 50 Lakh</option>
              <option>PKR 50L - 1 Crore</option>
              <option>PKR 1 - 2 Crore</option>
              <option>PKR 2 - 5 Crore</option>
              <option>PKR 5 Crore+</option>
            </select>
          </div>
          <div class="filter-group">
            <label>Area Size</label>
            <select>
              <option value="">Any Size</option>
              <option>Under 5 Marla</option>
              <option>5 - 10 Marla</option>
              <option>10 Marla - 1 Kanal</option>
              <option>1 Kanal+</option>
            </select>
          </div>
          <a class="search-btn" href="@listingsUrl"><i class="ti ti-search"></i> Search</a>
        </div>
      </div>
    </div>
  </section>

  <!-- POPULAR AREAS -->
  <section class="section section-gray">
    <div style="max-width:1100px;margin:0 auto">
      <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:24px">
        <div>
          <p class="section-eyebrow">Explore by Area</p>
          <h2 class="section-title">Popular Karachi Locations</h2>
        </div>
        <a href="@listingsUrl" style="font-size:13px;color:var(--teal);font-weight:600">View all areas -></a>
      </div>
      <div class="areas-grid">
        <a class="area-card" href="@listingsUrl">
          <div class="area-icon"><i class="ti ti-shield"></i></div>
          <div><div class="area-name">DHA Defence</div><div class="area-count">@getLocationCount("DHA Defence") active listings</div></div>
        </a>
        <a class="area-card" href="@listingsUrl">
          <div class="area-icon"><i class="ti ti-waves"></i></div>
          <div><div class="area-name">Clifton</div><div class="area-count">@getLocationCount("Clifton") active listings</div></div>
        </a>
        <a class="area-card" href="@listingsUrl">
          <div class="area-icon"><i class="ti ti-trees"></i></div>
          <div><div class="area-name">Gulshan-e-Iqbal</div><div class="area-count">@getLocationCount("Gulshan-e-Iqbal") active listings</div></div>
        </a>
        <a class="area-card" href="@listingsUrl">
          <div class="area-icon"><i class="ti ti-flower"></i></div>
          <div><div class="area-name">Gulistan-e-Jauhar</div><div class="area-count">@getLocationCount("Gulistan-e-Jauhar") active listings</div></div>
        </a>
        <a class="area-card" href="@listingsUrl">
          <div class="area-icon"><i class="ti ti-building-community"></i></div>
          <div><div class="area-name">Bahria Town Karachi</div><div class="area-count">@getLocationCount("Bahria Town Karachi") active listings</div></div>
        </a>
        <a class="area-card" href="@listingsUrl">
          <div class="area-icon"><i class="ti ti-map-pin"></i></div>
          <div><div class="area-name">Scheme 33</div><div class="area-count">@getLocationCount("Scheme 33") active listings</div></div>
        </a>
        <a class="area-card" href="@listingsUrl">
          <div class="area-icon"><i class="ti ti-home"></i></div>
          <div><div class="area-name">Malir</div><div class="area-count">@getLocationCount("Malir") active listings</div></div>
        </a>
        <a class="area-card" href="@listingsUrl">
          <div class="area-icon"><i class="ti ti-building"></i></div>
          <div><div class="area-name">North Nazimabad</div><div class="area-count">@getLocationCount("North Nazimabad") active listings</div></div>
        </a>
      </div>
    </div>
  </section>

  <!-- FEATURED PROPERTIES -->
  <section class="section">
    <div style="max-width:1100px;margin:0 auto">
      <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:24px">
        <div>
          <p class="section-eyebrow">Hand-Picked Listings</p>
          <h2 class="section-title">Featured Properties</h2>
        </div>
        <a href="@listingsUrl" style="font-size:13px;color:var(--teal);font-weight:600">View all listings -></a>
      </div>
      <div class="properties-grid">
        @if (Model != null && Model.Any())
        {
            foreach (var property in Model)
            {
                @Html.Partial("_PropertyCard", property)
            }
        }
        else
        {
            <div class="card-base" style="padding:24px;grid-column:1/-1;text-align:center">
              <p class="section-eyebrow">Coming Soon</p>
              <h2 class="section-title">Featured properties will appear after the database is updated.</h2>
            </div>
        }
      </div>
    </div>
  </section>
  <!-- WHY CHOOSE US -->
  <section class="section section-gray">
    <div style="max-width:1100px;margin:0 auto;text-align:center">
      <p class="section-eyebrow">Why Us</p>
      <h2 class="section-title" style="margin-bottom:28px">Why Choose Karachi Estate Hub?</h2>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon"><i class="ti ti-shield-check"></i></div>
          <div class="why-title">Verified Listings</div>
          <div class="why-desc">Every property is reviewed for accuracy before going live on our platform.</div>
        </div>
        <div class="why-card">
          <div class="why-icon"><i class="ti ti-map-search"></i></div>
          <div class="why-title">Karachi-Focused Search</div>
          <div class="why-desc">Hyper-local filters for every area, society, and block across Karachi.</div>
        </div>
        <div class="why-card">
          <div class="why-icon"><i class="ti ti-message-circle"></i></div>
          <div class="why-title">Direct Agent Contact</div>
          <div class="why-desc">WhatsApp and call sellers directly - no middlemen, no unnecessary delays.</div>
        </div>
        <div class="why-card">
          <div class="why-icon"><i class="ti ti-file-plus"></i></div>
          <div class="why-title">Easy Property Posting</div>
          <div class="why-desc">List your property in minutes with our guided step-by-step form - it's free.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <i class="ti ti-building-skyscraper" style="font-size:42px;color:rgba(255,255,255,.3);margin-bottom:14px;display:block"></i>
    <h2>Want to sell or rent your property?</h2>
    <p>Reach thousands of active buyers and renters across Karachi today.</p>
    <a href="@addPropertyUrl" class="cta-btn">Post Your Property - It's Free</a>
  </section>
