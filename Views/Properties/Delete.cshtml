@model KarachiEstateHub.Models.Property
@{
    ViewBag.Title = "Delete Property";
    var myPropertiesUrl = Url.RouteUrl("MyProperties");
}

<div class="add-prop-layout">
    <div class="auth-form-card" style="max-width:620px;margin:0 auto">
        <div class="auth-logo">
            <div class="auth-logo-icon"><i class="ti ti-alert-triangle"></i></div>
            <div class="auth-form-title">Delete Property</div>
            <div class="auth-form-sub">This action cannot be undone.</div>
        </div>

        <h2 class="section-title" style="margin-bottom:14px">Are you sure you want to delete this property?</h2>

        <div class="card-base" style="padding:16px;margin-bottom:18px">
            <div class="prop-list-price">@(!String.IsNullOrWhiteSpace(Model.PriceLabel) ? Model.PriceLabel : String.Format("PKR {0:N0}", Model.Price))</div>
            <div class="prop-list-title">@Model.Title</div>
            <div class="prop-list-loc"><i class="ti ti-map-pin"></i> @(Model.Location != null ? Model.Location.Name : "Karachi")</div>
            <div style="margin-top:10px"><span class="status-pill status-pending">@Model.Status</span></div>
        </div>

        @using (Html.BeginForm("Delete", "Properties", new { id = Model.PropertyId }, FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <div style="display:flex;gap:8px;justify-content:flex-end">
                <a class="btn-outline" href="@myPropertiesUrl">Cancel</a>
                <button class="btn-danger-keh" type="submit"><i class="ti ti-trash"></i> Delete Property</button>
            </div>
        }
    </div>
</div>
