@model KarachiEstateHub.ViewModels.PropertyListViewModel
@{
    ViewBag.Title = "Properties";
    var listingsUrl = Url.RouteUrl("Listings");
}

<div class="listing-layout">
    <aside class="listing-sidebar">
        <form method="get" action="@listingsUrl">
            <div class="sidebar-title">Filter Properties</div>

            <div class="filter-block">
                <div class="filter-block-title">Purpose</div>
                <label class="filter-check">
                    <input type="radio" name="purpose" value="Sale" @(Model.Purpose == "Sale" ? "checked" : "") />
                    For Sale
                </label>
                <label class="filter-check">
                    <input type="radio" name="purpose" value="Rent" @(Model.Purpose == "Rent" ? "checked" : "") />
                    For Rent
                </label>
            </div>

            <div class="filter-block">
                <div class="filter-block-title">Property Type</div>
                <select class="sort-select" name="propertyTypeId" style="width:100%">
                    <option value="">All Types</option>
                    @foreach (var type in Model.PropertyTypes)
                    {
                        <option value="@type.PropertyTypeId" @(Model.PropertyTypeId == type.PropertyTypeId ? "selected" : "")>@type.Name</option>
                    }
                </select>
            </div>

            <div class="filter-block">
                <div class="filter-block-title">Location</div>
                <select class="sort-select" name="locationId" style="width:100%">
                    <option value="">Any Area</option>
                    @foreach (var location in Model.Locations)
                    {
                        <option value="@location.LocationId" @(Model.LocationId == location.LocationId ? "selected" : "")>@location.Name</option>
                    }
                </select>
            </div>

            <div class="filter-block">
                <div class="filter-block-title">Bedrooms</div>
                <div class="bed-btns">
                    @foreach (var bed in new[] { 1, 2, 3, 4, 5 })
                    {
                        <label class="bed-btn @(Model.Bedrooms == bed ? "active" : "")">
                            <input type="radio" name="bedrooms" value="@bed" style="display:none" @(Model.Bedrooms == bed ? "checked" : "") />
                            @(bed == 5 ? "5+" : bed.ToString())
                        </label>
                    }
                </div>
            </div>

            <div class="filter-block">
                <div class="filter-block-title">Price Range</div>
                <div class="price-inputs">
                    <input type="number" name="minPrice" value="@Model.MinPrice" placeholder="Min" />
                    <input type="number" name="maxPrice" value="@Model.MaxPrice" placeholder="Max" />
                </div>
            </div>

            <div class="filter-block">
                <div class="filter-block-title">Highlights</div>
                <label class="filter-check">
                    <input type="checkbox" name="isFeatured" value="true" @(Model.IsFeatured == true ? "checked" : "") />
                    Featured only
                </label>
                <label class="filter-check">
                    <input type="checkbox" name="isVerified" value="true" @(Model.IsVerified == true ? "checked" : "") />
                    Verified only
                </label>
            </div>

            <input type="hidden" name="sort" value="@Model.Sort" />
            <button class="sidebar-apply" type="submit">Apply Filters</button>
            <a class="sidebar-reset" href="@listingsUrl" style="display:block;text-align:center">Reset Filters</a>
        </form>
    </aside>

    <main class="listing-results">
        <div class="results-toolbar">
            <div>
                <p class="section-eyebrow">Karachi Properties</p>
                <div class="results-count"><strong>@Model.ResultCount</strong> active listings found</div>
            </div>
            <div class="toolbar-right">
                <form method="get" action="@listingsUrl">
                    <input type="hidden" name="purpose" value="@Model.Purpose" />
                    <input type="hidden" name="propertyTypeId" value="@Model.PropertyTypeId" />
                    <input type="hidden" name="locationId" value="@Model.LocationId" />
                    <input type="hidden" name="bedrooms" value="@Model.Bedrooms" />
                    <input type="hidden" name="minPrice" value="@Model.MinPrice" />
                    <input type="hidden" name="maxPrice" value="@Model.MaxPrice" />
                    @if (Model.IsFeatured == true)
                    {
                        <input type="hidden" name="isFeatured" value="true" />
                    }
                    @if (Model.IsVerified == true)
                    {
                        <input type="hidden" name="isVerified" value="true" />
                    }
                    <select class="sort-select" name="sort" onchange="this.form.submit()">
                        <option value="newest" @(Model.Sort == "newest" ? "selected" : "")>Newest First</option>
                        <option value="priceLow" @(Model.Sort == "priceLow" ? "selected" : "")>Price: Low to High</option>
                        <option value="priceHigh" @(Model.Sort == "priceHigh" ? "selected" : "")>Price: High to Low</option>
                    </select>
                </form>
                <button class="view-btn active" type="button"><i class="ti ti-layout-grid"></i></button>
            </div>
        </div>

        @if (!Model.Properties.Any())
        {
            <div class="card-base" style="padding:32px;text-align:center">
                <p class="section-eyebrow">No Results</p>
                <h2 class="section-title">No active properties match these filters.</h2>
            </div>
        }
        else
        {
            <div class="results-grid">
                @foreach (var property in Model.Properties)
                {
                    var purposeBadgeClass = property.Purpose == "Rent" ? "badge-rent" : "badge-sale";
                    var purposeText = property.Purpose == "Rent" ? "For Rent" : "For Sale";
                    var gradient = !String.IsNullOrWhiteSpace(property.GradientCss) ? property.GradientCss : "linear-gradient(135deg,#0D6B5E,#1a8a7a)";
                    var iconClass = !String.IsNullOrWhiteSpace(property.IconClass) ? property.IconClass : "ti ti-building-estate";
                    var phone = !String.IsNullOrWhiteSpace(property.ContactNumber) ? property.ContactNumber : (property.User != null ? property.User.Phone : null);
                    var whatsAppSource = !String.IsNullOrWhiteSpace(property.WhatsAppNumber) ? property.WhatsAppNumber : phone;
                    var whatsAppPhone = !String.IsNullOrWhiteSpace(whatsAppSource) ? whatsAppSource.Replace("+", "").Replace(" ", "").Replace("-", "").Replace("(", "").Replace(")", "") : null;
                    var areaText = property.AreaSize + (!String.IsNullOrWhiteSpace(property.AreaUnit) ? " " + property.AreaUnit : "");
                    var price = !String.IsNullOrWhiteSpace(property.PriceLabel) ? property.PriceLabel : String.Format("PKR {0:N0}", property.Price);
                    var activeImages = (property.Images ?? Enumerable.Empty<KarachiEstateHub.Models.PropertyImage>())
                        .Where(i => i != null && i.IsActive && !String.IsNullOrWhiteSpace(i.ImageUrl))
                        .ToList();
                    var mainImage = activeImages
                        .OrderByDescending(i => i.IsPrimary)
                        .ThenBy(i => i.SortOrder)
                        .FirstOrDefault();

                    <div class="prop-card-list">
                        <div class="prop-list-img" style="background:@gradient">
                            @if (mainImage != null)
                            {
                                <img class="property-image-cover" src="@Url.Content(mainImage.ImageUrl)" alt="@(!String.IsNullOrWhiteSpace(mainImage.AltText) ? mainImage.AltText : property.Title)" onerror="this.style.display='none';" />
                            }
                            else
                            {
                                <div class="prop-list-img-inner">
                                    <i class="@iconClass"></i>
                                </div>
                            }
                            <div class="prop-badges">
                                <span class="pill @purposeBadgeClass">@purposeText</span>
                                @if (property.IsFeatured)
                                {
                                    <span class="pill badge-featured">Featured</span>
                                }
                                @if (property.IsVerified)
                                {
                                    <span class="pill badge-verified">✓ Verified</span>
                                }
                            </div>
                        </div>
                        <div class="prop-list-body">
                            <div class="prop-list-price">@price</div>
                            <div class="prop-list-title">@property.Title</div>
                            <div class="prop-list-loc"><i class="ti ti-map-pin"></i> @(property.Location != null ? property.Location.Name : "Karachi")</div>
                            <div class="prop-list-specs">
                                @if (property.Bedrooms > 0)
                                {
                                    <span class="prop-list-spec"><i class="ti ti-bed"></i> @property.Bedrooms Beds</span>
                                }
                                @if (property.Bathrooms > 0)
                                {
                                    <span class="prop-list-spec"><i class="ti ti-bath"></i> @property.Bathrooms Baths</span>
                                }
                                <span class="prop-list-spec"><i class="ti ti-maximize"></i> @areaText</span>
                            </div>
                            <div class="prop-actions">
                                <a class="prop-btn-main" href="@Url.RouteUrl("ListingDetails", new { id = property.PropertyId })">View Details</a>

                                @if (!String.IsNullOrWhiteSpace(whatsAppPhone))
                                {
                                    <a class="prop-btn-icon wa" href="https://wa.me/@whatsAppPhone" target="_blank" rel="noopener" title="WhatsApp" aria-label="WhatsApp">
                                        <svg class="prop-btn-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                            <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9" />
                                            <path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 -.5 .5" />
                                        </svg>
                                    </a>
                                }

                                @if (!String.IsNullOrWhiteSpace(phone))
                                {
                                    <a class="prop-btn-icon call" href="tel:@phone" title="Call" aria-label="Call">
                                        <svg class="prop-btn-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                            <path d="M5 4h4l2 5l-2.5 1.5a11 11 0 0 0 5 5l1.5 -2.5l5 2v4a2 2 0 0 1 -2 2a16 16 0 0 1 -15 -15a2 2 0 0 1 2 -2" />
                                        </svg>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </main>
</div>
