@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" style="margin:16px auto 0;max-width:1100px;border-radius:8px" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" style="margin:16px auto 0;max-width:1100px;border-radius:8px" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
