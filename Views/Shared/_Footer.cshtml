@{
    var footerRole = Session["UserRole"] as string;
    var footerCanAddProperty = footerRole == "Admin" || footerRole == "Agent";
    var footerCreateUrl = Url.RouteUrl("CreateListing");
    var footerAddPropertyUrl = footerCanAddProperty
        ? footerCreateUrl
        : Url.Action("Login", "Account", new { returnUrl = footerCreateUrl, message = "addProperty" });
    var footerListingsUrl = Url.RouteUrl("Listings");
    var footerSaleUrl = Url.RouteUrl("Listings", new { purpose = "Sale" });
    var footerRentUrl = Url.RouteUrl("Listings", new { purpose = "Rent" });
}

<footer class="footer">
    <div style="max-width:1100px;margin:0 auto">
        <div class="footer-grid">
            <div>
                <div class="footer-logo-row">
                    <div class="footer-logo-icon">
                        <svg class="footer-logo-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M3 21h18" />
                            <path d="M5 21V7l7-4l7 4v14" />
                            <path d="M9 21v-8h6v8" />
                        </svg>
                    </div>
                    <span class="footer-logo-text">Karachi Estate Hub</span>
                </div>
                <p class="footer-about">Karachi's most trusted platform for buying, selling, and renting residential and commercial properties.</p>
                <div class="footer-socials">
                    <a class="footer-social-btn" href="#" aria-label="Facebook" title="Facebook">
                        <svg class="footer-social-svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M15 8h2.2V4.3A20 20 0 0 0 14 4c-3.2 0-5.3 1.9-5.3 5.4V12H5.3v4.1h3.4V24h4.2v-7.9h3.3l.5-4.1h-3.8V9.8c0-1.2.3-1.8 2.1-1.8z" />
                        </svg>
                    </a>
                    <a class="footer-social-btn" href="#" aria-label="Instagram" title="Instagram">
                        <svg class="footer-social-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <rect x="4" y="4" width="16" height="16" rx="4" />
                            <circle cx="12" cy="12" r="3.3" />
                            <path d="M16.8 7.2h.01" />
                        </svg>
                    </a>
                    <a class="footer-social-btn" href="https://wa.me/923000000000" target="_blank" rel="noopener" aria-label="WhatsApp" title="WhatsApp">
                        <svg class="footer-social-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M3 21l1.65-3.8A9 9 0 1 1 8.1 20L3 21z" />
                            <path d="M9 8.5c.3 3.4 3.1 6.2 6.5 6.5" />
