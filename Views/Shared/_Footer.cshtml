                        </svg>
                    </a>
                    <a class="footer-social-btn" href="#" aria-label="YouTube" title="YouTube">
                        <svg class="footer-social-svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M21.6 7.2a3 3 0 0 0-2.1-2.1C17.7 4.6 12 4.6 12 4.6s-5.7 0-7.5.5a3 3 0 0 0-2.1 2.1A31 31 0 0 0 2 12a31 31 0 0 0 .4 4.8a3 3 0 0 0 2.1 2.1c1.8.5 7.5.5 7.5.5s5.7 0 7.5-.5a3 3 0 0 0 2.1-2.1A31 31 0 0 0 22 12a31 31 0 0 0-.4-4.8zM10 15.4V8.6l6 3.4l-6 3.4z" />
