        <div class="footer-bottom">
            <p>Copyright 2025 Karachi Estate Hub. All rights reserved.</p>
            <div>
                <a href="@Url.Action("About", "Home")">About</a>
                <a href="@Url.Action("Contact", "Home")">Contact</a>
                <a href="@footerListingsUrl">Sitemap</a>
            </div>
        </div>
    </div>
</footer>
