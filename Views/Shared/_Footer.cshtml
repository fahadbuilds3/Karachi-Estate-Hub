            <div>
                <div class="footer-col-title">Quick Links</div>
                <a class="footer-link" href="@footerSaleUrl">Buy Property</a>
                <a class="footer-link" href="@footerRentUrl">Rent Property</a>
                <a class="footer-link" href="@footerAddPropertyUrl">Sell Property</a>
                <a class="footer-link" href="@Url.Action("About", "Home")">Find Agents</a>
                <a class="footer-link" href="@Url.Action("Contact", "Home")">Contact Us</a>
