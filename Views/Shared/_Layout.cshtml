<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Karachi Estate Hub</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/%40tabler/icons-webfont%403.4.0/tabler-icons.min.css" rel="stylesheet" />
    <link href="@Url.Content("~/Content/keh.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/keh.css?v=45")" rel="stylesheet" />
</head>
<body>
    @Html.Partial("_Navbar")

    @Html.Partial("_Alerts")

    @RenderBody()

    @Html.Partial("_Footer")

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="@Url.Content("~/Scripts/keh.js")"></script>
    <script src="@Url.Content("~/Scripts/keh.js?v=31")"></script>
    @RenderSection("scripts", required: false)
</body>
</html>
